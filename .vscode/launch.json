  "version": "0.2.0",
  "configurations": [
    {
      "type": "factorio",
      "request": "launch",
      "name": "Factorio Mod Debug",
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "lua-local",
      "request": "launch",
      "name": "Busted Debug (Current File)",
      "program": {
        "command": "busted"
      },
      "cwd": "${workspaceFolder}",
      "args": ["${relativeFile}"],
      "stopOnEntry": false,
      "ignorePatterns": ["/lua_modules/", "/spec/helper.lua$"]
    }
  ]
}
