{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug",
      "adjustModSettings": [
        {
          "name": "mks-dsl-is-development",
          "scope": "startup",
          "value": true
        }
      ]
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Clean Mod List)",
      "disableExtraMods": true,
      "adjustMods": {
        "elevated-rails": true,
        "quality": true,
        "space-age": true,
        "disco-science-lite": true
      },
      "adjustModSettings": [
        {
          "name": "mks-dsl-is-development",
          "scope": "startup",
          "value": true
        }
      ]
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Settings & Data)",
      "hookSettings": true,
      "hookData": true,
      "adjustModSettings": [
        {
          "name": "mks-dsl-is-development",
          "scope": "startup",
          "value": true
        }
      ]
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Profile)",
      "hookMode": "profile"
    },
    {
      "type": "lua-local",
      "request": "launch",
      "name": "Busted Debug (Current File)",
      "program": {
        "command": "busted"
      },
      "cwd": "${workspaceFolder}",
      "args": ["${relativeFile}"],
      "stopOnEntry": false,
      "ignorePatterns": ["/lua_modules/", "/spec/helper.lua$"]
    }
  ]
}
