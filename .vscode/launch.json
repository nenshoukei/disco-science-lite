{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug",
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Clean Mod List)",
      "disableExtraMods": true,
      "adjustMods": {
        "elevated-rails": true,
        "quality": true,
        "space-age": true,
        "disco-science-lite": true
      },
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Showcase for gallery)",
      "disableExtraMods": true,
      "adjustMods": {
        "elevated-rails": true,
        "quality": true,
        "space-age": true,
        "Age-of-Production": true,
        "Age-of-Production-Graphics": true,
        "bioprocessing-tab": true,
        "CircularColliderLab": true,
        "Cold_biters": true,
        "corrundum": true,
        "dea-dia-system": true,
        "disco-science-lite": true,
        "est-tiny-storage-tank": true,
        "fusion-lab": true,
        "LabOMatic": true,
        "lex-aircraft": true,
        "PlanetsLib": true,
        "quality_glassware": true,
        "Robocharger-Updated": true,
        "SpidertronEnhancements": true,
        "SpidertronPatrols": true
      },
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Settings & Data)",
      "hookSettings": true,
      "hookData": true,
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "factoriomod",
      "request": "launch",
      "name": "Factorio Mod Debug (Profile)",
      "hookMode": "profile",
      "tags": {
        "dsl_is_development": true
      }
    },
    {
      "type": "lua-local",
      "request": "launch",
      "name": "Busted Debug (Current File)",
      "program": {
        "command": "busted"
      },
      "cwd": "${workspaceFolder}",
      "args": ["${relativeFile}"],
      "stopOnEntry": false,
      "ignorePatterns": ["/lua_modules/", "/spec/helper.lua$"]
    }
  ]
}
